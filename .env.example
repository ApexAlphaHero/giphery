# ===========================================================================
# Giphery server configuration — copy to .env and fill in real values.
# NEVER commit the real .env. Generate strong random secrets (see commands).
# ===========================================================================

# --- Core ------------------------------------------------------------------
# Environment: "development" | "production". Controls docs gating, CORS, etc.
GIPHERY_ENV=production

# Public base URL the API is reached at (through SWAG). Used to build absolute
# URLs (e.g. GIF raw links) and to validate redirect/origin assumptions.
# e.g. https://giphery.example.com
PUBLIC_BASE_URL=https://giphery.example.com

# --- Security / crypto -----------------------------------------------------
# JWT signing secret (HS256). Generate: openssl rand -hex 32
SECRET_KEY=change-me-32-byte-hex

# Symmetric key used to encrypt invitation codes at rest (Fernet/AES-GCM).
# Generate a urlsafe 32-byte base64 key:
#   python -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
INVITE_ENC_KEY=change-me-urlsafe-base64-32-bytes

# JWT algorithm: HS256 (default) or RS256/EdDSA (then set key paths instead).
JWT_ALGORITHM=HS256

# Token issuer / audience claims (validated on every token).
JWT_ISSUER=giphery
JWT_AUDIENCE=giphery-clients

# Token lifetimes.
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=60

# --- Database --------------------------------------------------------------
# Compose wires these into the db service and the async DSN below.
POSTGRES_USER=giphery
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=giphery
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Async SQLAlchemy DSN (asyncpg). Built from the above by config.py if unset.
# DATABASE_URL=postgresql+asyncpg://giphery:password@db:5432/giphery

# --- Storage ---------------------------------------------------------------
# Path inside the container where GIF files are stored (mapped to a volume).
MEDIA_ROOT=/data/media
# Max upload size in bytes (default 16 MiB).
MAX_UPLOAD_BYTES=16777216

# --- CORS ------------------------------------------------------------------
# Comma-separated allowed origins for the web UI / clients. "*" is rejected
# in production. The Android app uses native HTTP and is not CORS-bound.
CORS_ALLOWED_ORIGINS=https://giphery.example.com

# --- Rate limiting ---------------------------------------------------------
# Optional Redis backend for distributed rate limiting. If unset, in-process.
# REDIS_URL=redis://redis:6379/0
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REDEEM=5/minute

# --- API docs --------------------------------------------------------------
# Enable interactive OpenAPI docs (/docs, /redoc). MUST be false in prod.
ENABLE_DOCS=false

# --- Uvicorn / app ---------------------------------------------------------
APP_PORT=8000
LOG_LEVEL=info

# --- Logging (24h rolling troubleshooting log) -----------------------------
# Directory inside the container for the rolling app log (mapped to a volume
# so it survives restarts). One file per hour, retained 24h then auto-deleted.
LOG_DIR=/data/logs
# Hours of history to keep (rotation count). 24 = last 24 hours.
LOG_RETENTION_HOURS=24
# Emit logs as structured JSON lines (recommended) or plain text.
LOG_JSON=true
