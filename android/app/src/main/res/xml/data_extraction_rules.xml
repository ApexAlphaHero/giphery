<?xml version="1.0" encoding="utf-8"?>
<!-- Exclude the encrypted token store from cloud backup and device transfer. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="giphery_secure_tokens.xml" />
        <exclude domain="file" path="datastore/" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="giphery_secure_tokens.xml" />
        <exclude domain="file" path="datastore/" />
    </device-transfer>
</data-extraction-rules>
