<?xml version="1.0" encoding="utf-8"?>
<!--
  HTTPS only. Cleartext is disabled globally. The server is reached through
  SWAG (TLS). If you must test against a self-signed cert during development,
  add a debug-only <debug-overrides> trust anchor here — never in release.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
